#!/usr/bin/env ruby

require 'awesome_print'

##############################
FRACTIONS = {
  :r => 0.20, # BRES
  :o => 0.80, # BOPS
  :q => nil,  # QCDDAT (nil, since 'optional' project)
}
##############################

# usage
unless ARGV.length > 0
  $stderr.puts """
  USAGE #{File.basename $0} [NUM DAYS]... [SUBTRACTIONS]...

  NUM_DAYS   number of days in timesheet period; delimit
             by spaces (to add them)

  WORKED     (optional) each argument should be a project code,
             a comma, then the number of hours worked
             default: 0 for all projects
  """
  exit 2
end

# parse arguments
num_da   = 0.0
wrk_hash = FRACTIONS.keys.map{ |it| [it, 0.0] }.to_h
ARGV.each do |arg|
  case arg
  when /,/
    proj  = arg.split(',')[0].to_sym
    hours = arg.split(',')[1].to_f
    raise "project '#{proj}' not found" unless wrk_hash.has_key? proj
    wrk_hash[proj] += hours.to_f
  else
    num_da += arg.to_f
  end
end

# total required hours
req_hours_total  = num_da * 8

# total required hours, after subtracting optional projects
req_hours_subbed = req_hours_total
FRACTIONS.each do |proj,frac|
  req_hours_subbed -= wrk_hash[proj] if frac.nil?
end

# calculate required hours for each project, subtracting worked hours
req_hash = FRACTIONS.map do |proj,frac|
  if frac.nil?
    [proj, 0.0]
  else
    [proj, req_hours_subbed * frac - wrk_hash[proj]]
  end
end.to_h

# print
ap({num_da:}, color: {float: :red })
ap({wrk_hash:}, color: {float: :red })
ap({req_hash:}, color: {float: :red })
